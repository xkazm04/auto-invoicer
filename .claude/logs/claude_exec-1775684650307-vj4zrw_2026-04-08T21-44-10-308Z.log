1\t    native_name VARCHAR(100),\n252\t    currency VARCHAR(3) NOT NULL,\n253\t    currency_symbol VARCHAR(5),\n254\t    vat_rates JSONB NOT NULL DEFAULT '[]',\n255\t    -- Example: [{\"rate\": 21, \"name\": \"standard\"}, {\"rate\": 12, \"name\": \"reduced\"}, {\"rate\": 0, \"name\": \"zero\"}]\n256\t    invoice_rules JSONB NOT NULL DEFAULT '{}',\n257\t    -- Country-specific required fields, formats, validations\n258\t    tax_id_label VARCHAR(50),  -- \"IČO\", \"Steuernummer\", \"Company Number\"\n259\t    tax_id_format VARCHAR(100),  -- Regex pattern\n260\t    vat_id_prefix VARCHAR(5),  -- \"CZ\", \"DE\", \"GB\"\n261\t    vat_id_format VARCHAR(100),\n262\t    date_format VARCHAR(20) DEFAULT 'dd.MM.yyyy',\n263\t    number_format JSONB DEFAULT '{\"decimal\": \",\", \"thousand\": \" \"}',\n264\t    payment_methods JSONB DEFAULT '[]',\n265\t    created_at TIMESTAMPTZ DEFAULT NOW()\n266\t);\n267\t\n268\t-- Users (extends Supabase auth.users)\n269\tCREATE TABLE users (\n270\t    id UUID PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,\n271\t    email VARCHAR(255) NOT NULL,\n272\t    full_name VARCHAR(255),\n273\t    avatar_url TEXT,\n274\t    locale VARCHAR(10) DEFAULT 'en',\n275\t    timezone VARCHAR(50) DEFAULT 'UTC',\n276\t    onboarding_completed BOOLEAN DEFAULT FALSE,\n277\t    preferences JSONB DEFAULT '{}',\n278\t    created_at TIMESTAMPTZ DEFAULT NOW(),\n279\t    updated_at TIMESTAMPTZ DEFAULT NOW()\n280\t);\n281\t\n282\t-- Organizations (business entities)\n283\tCREATE TABLE organizations (\n284\t    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n285\t    owner_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,\n286\t    name VARCHAR(255) NOT NULL,\n287\t    country_code VARCHAR(2) NOT NULL REFERENCES country_configs(code),\n288\t    entity_type entity_type NOT NULL,\n289\t    \n290\t    -- Tax identifiers (country-specific)\n291\t    tax_id VARCHAR(50),  -- IČO, Company Number, etc.\n292\t    vat_id VARCHAR(50),  -- DIČ, VAT Number, USt-IdNr.\n293\t    is_vat_payer BOOLEAN DEFAULT FALSE,\n294\t    \n295\t    -- Address\n296\t    address_line1 VARCHAR(255),\n297\t    address_line2 VARCHAR(255),\n298\t    city VARCHAR(100),\n299\t    postal_code VARCHAR(20),\n300\t    region VARCHAR(100),\n[result-id: r6]"}]},"parent_tool_use_id":"toolu_01B24bGzbWozuAkJerWXmjz8","session_id":"3222cf1b-2930-4f4b-a1c0-9f3e8ac0d429","uuid":"ea580fd8-a5ee-4baa-8cca-7f1e16d9d310","timestamp":"2026-04-08T21:44:42.458Z"}
